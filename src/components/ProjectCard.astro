---
interface Props {
	title: string;
	description: string;
	tech: string;
	url?: string;
}
const { title, description, tech, url = '#' } = Astro.props;
---

<a href={url} class="project-card">
	<div class="card-top">
		<span class="card-title">{title}</span>
		<span class="badge">{tech}</span>
	</div>
	<p class="card-desc">{description}</p>
</a>

<style>
.project-card {
	display: block;
	background: var(--surface);
	border: 0.5px solid var(--border);
	border-radius: 8px;
	padding: 12px 14px;
	text-decoration: none;
	margin-bottom: 8px;
	transition: border-color 0.2s ease;
}
.project-card:hover {
	border-color: var(--accent);
}
.card-top {
	display: flex;
	align-items: center;
	gap: 8px;
	margin-bottom: 4px;
}
.card-title {
	font-size: 13px;
	font-weight: 500;
	color: var(--text-primary);
}
:global(.dark) .card-title {
	color: #f2f0e8;
}
.badge {
	font-size: 10px;
	font-weight: 500;
	padding: 2px 7px;
	border-radius: 4px;
	background: var(--accent-subtle);
	color: var(--accent);
}
.card-desc {
	font-size: 12px;
	color: var(--text-muted);
	margin: 0;
}
</style>
