---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<div class="left">
			<h2><a href="/">{SITE_TITLE}</a></h2>
		</div>
		<div class="center">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/portofolio">Portfolio</HeaderLink>
		</div>
		<div class="right">
			<a href="https://github.com/" target="_blank">GitHub</a>
			<a href="/rss.xml">RSS</a>
		</div>
	</nav>
</header>
<style>
	header {
		padding: 1.5rem 2rem;
		max-width: 900px;
		margin: 0 auto;
	}
	nav {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
	}
	nav h2 {
		font-size: 1.1rem;
		font-weight: 600;
	}
	h2 a {
		text-decoration: none;
		color: #333;
	}
	nav a {
		text-decoration: none;
		color: #666;
		font-size: 0.95rem;
		margin-left: 1rem;
	}
	nav a:hover {
		color: #000;
	}
	.left, .center, .right {
		display: flex;
		align-items: center;
	}
	@media (max-width: 600px) {
		nav { flex-wrap: wrap; }
		.center { order: 3; width: 100%; justify-content: center; margin-top: 0.5rem; }
		.center a { margin: 0 0.5rem; }
	}
</style>