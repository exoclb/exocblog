---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<div class="left">
			<h2><a href="/">{SITE_TITLE}</a></h2>
		</div>
		<div class="center">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/search">Search</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/portfolio">Portfolio</HeaderLink>
		</div>
		<div class="right">
			<a href="https://github.com/" target="_blank">GitHub</a>
			<a href="/rss.xml">RSS</a>
			<button id="theme-toggle" aria-label="Toggle dark mode">
				<svg class="sun" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
				<svg class="moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
			</button>
		</div>
	</nav>
</header>

<script is:inline>
	const theme = (() => {
		if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
			return localStorage.getItem('theme');
		}
		if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
			return 'dark';
		}
		return 'light';
	})();

	if (theme === 'dark') {
		document.documentElement.classList.add('dark');
	} else {
		document.documentElement.classList.remove('dark');
	}

	window.localStorage.setItem('theme', theme);

	const handleToggleClick = () => {
		const element = document.documentElement;
		element.classList.toggle('dark');

		const isDark = element.classList.contains('dark');
		localStorage.setItem('theme', isDark ? 'dark' : 'light');
	};

	document.getElementById('theme-toggle').addEventListener('click', handleToggleClick);
</script>
<style>
	header {
		padding: 1.5rem 2rem;
		max-width: 900px;
		margin: 0 auto;
	}
	nav {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
	}
	nav h2 {
		font-size: 1.1rem;
		font-weight: 600;
	}
	h2 a {
		text-decoration: none;
		color: #333;
	}
	nav a {
		text-decoration: none;
		color: #666;
		font-size: 0.95rem;
		margin-left: 1rem;
	}
	nav a:hover {
		color: #000;
	}
	:global(.dark) h2 a {
		color: #c9d1d9;
	}
	:global(.dark) nav a {
		color: #8b949e;
	}
	:global(.dark) nav a:hover {
		color: #c9d1d9;
	}
	.left, .center, .right {
		display: flex;
		align-items: center;
	}
	#theme-toggle {
		background: none;
		border: 1px solid #ddd;
		border-radius: 6px;
		cursor: pointer;
		padding: 0.4rem;
		margin-left: 0.5rem;
		color: #666;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.2s;
	}
	#theme-toggle:hover {
		background: #f5f5f5;
		color: #333;
	}
	:global(.dark) #theme-toggle {
		border-color: #30363d;
		color: #8b949e;
	}
	:global(.dark) #theme-toggle:hover {
		background: #21262d;
		color: #c9d1d9;
	}
	#theme-toggle .moon {
		display: none;
	}
	:global(.dark) #theme-toggle .sun {
		display: none;
	}
	:global(.dark) #theme-toggle .moon {
		display: block;
	}
	@media (max-width: 600px) {
		nav { flex-wrap: wrap; }
		.center { order: 3; width: 100%; justify-content: center; margin-top: 0.5rem; }
		.center a { margin: 0 0.5rem; }
	}
</style>