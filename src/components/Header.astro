---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<div class="left">
			<h2><a href="/">{SITE_TITLE}</a></h2>
		</div>
		<div class="center">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/search">Search</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/portofolio">Portfolio</HeaderLink>
		</div>
		<div class="right">
			<a href="https://github.com/" target="_blank">GitHub</a>
			<a href="/rss.xml">RSS</a>
			<button id="theme-toggle" aria-label="Toggle dark mode">
				<span class="sun">☀️</span>
				<span class="moon">🌙</span>
			</button>
		</div>
	</nav>
</header>

<script is:inline>
	const theme = (() => {
		if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
			return localStorage.getItem('theme');
		}
		if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
			return 'dark';
		}
		return 'light';
	})();

	if (theme === 'dark') {
		document.documentElement.classList.add('dark');
	} else {
		document.documentElement.classList.remove('dark');
	}

	window.localStorage.setItem('theme', theme);

	const handleToggleClick = () => {
		const element = document.documentElement;
		element.classList.toggle('dark');

		const isDark = element.classList.contains('dark');
		localStorage.setItem('theme', isDark ? 'dark' : 'light');
	};

	document.getElementById('theme-toggle').addEventListener('click', handleToggleClick);
</script>
<style>
	header {
		padding: 1.5rem 2rem;
		max-width: 900px;
		margin: 0 auto;
	}
	nav {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
	}
	nav h2 {
		font-size: 1.1rem;
		font-weight: 600;
	}
	h2 a {
		text-decoration: none;
		color: #333;
	}
	nav a {
		text-decoration: none;
		color: #666;
		font-size: 0.95rem;
		margin-left: 1rem;
	}
	nav a:hover {
		color: #000;
	}
	:global(.dark) h2 a {
		color: #eee;
	}
	:global(.dark) nav a {
		color: #aaa;
	}
	:global(.dark) nav a:hover {
		color: #fff;
	}
	.left, .center, .right {
		display: flex;
		align-items: center;
	}
	#theme-toggle {
		background: none;
		border: none;
		cursor: pointer;
		font-size: 1.1rem;
		padding: 0.25rem 0.5rem;
		margin-left: 0.5rem;
		opacity: 0.6;
		transition: opacity 0.2s;
	}
	#theme-toggle:hover {
		opacity: 1;
	}
	#theme-toggle .moon {
		display: none;
	}
	:global(.dark) #theme-toggle .sun {
		display: none;
	}
	:global(.dark) #theme-toggle .moon {
		display: inline;
	}
	@media (max-width: 600px) {
		nav { flex-wrap: wrap; }
		.center { order: 3; width: 100%; justify-content: center; margin-top: 0.5rem; }
		.center a { margin: 0 0.5rem; }
	}
</style>