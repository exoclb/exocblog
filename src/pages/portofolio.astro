---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const projects = [
	{
		title: 'Project 1',
		description: 'Description of your first project.',
		link: '#',
		tech: ['React', 'Node.js'],
	},
	{
		title: 'Project 2',
		description: 'Description of your second project.',
		link: '#',
		tech: ['Astro', 'Tailwind'],
	},
	{
		title: 'Project 3',
		description: 'Description of your third project.',
		link: '#',
		tech: ['Python', 'MongoDB'],
	},
];
---
<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Portfolio | ExocBlog" description="My projects and work" />
	</head>
	<body>
		<Header />
		<main>
			<h1>Portfolio</h1>
			<p>Here are some of my projects:</p>
			
			<div class="projects">
				{projects.map((project) => (
					<article class="project-card">
						<h2><a href={project.link}>{project.title}</a></h2>
						<p>{project.description}</p>
						<div class="tech">
							{project.tech.map((t) => (
								<span class="tech-tag">{t}</span>
							))}
						</div>
					</article>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>
<style>
	.projects {
		margin-top: 2rem;
	}
	.project-card {
		padding: 1.5rem 0;
		border-bottom: 1px solid #eee;
	}
	.project-card:last-child {
		border-bottom: none;
	}
	.project-card h2 {
		margin-bottom: 0.5rem;
	}
	.project-card h2 a {
		text-decoration: none;
		color: #333;
	}
	.project-card h2 a:hover {
		color: #000;
	}
	.project-card p {
		color: #666;
		margin-bottom: 0.75rem;
	}
	.tech {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}
	.tech-tag {
		background: #eee;
		padding: 0.25rem 0.5rem;
		border-radius: 4px;
		font-size: 0.8rem;
		color: #555;
	}
</style>