---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const allTags = [...new Set(posts.flatMap(post => post.data.tags || []))];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Search | ExocBlog" description="Search posts" />
		<script>
			let allPosts = [];

			async function loadPosts() {
				const response = await fetch('/search.json');
				allPosts = await response.json();
			}

			function searchPosts(query) {
				if (!query) return [];
				const q = query.toLowerCase();
				return allPosts.filter(post => {
					const searchText = (post.title + ' ' + post.description + ' ' + (post.tags || []).join(' ')).toLowerCase();
					return searchText.includes(q);
				});
			}

			function renderResults(results) {
				const container = document.getElementById('results');
				if (!container) return;
				
				if (results.length === 0) {
					container.innerHTML = '<li><p>No results found.</p></li>';
					return;
				}

				container.innerHTML = results.map(post => `
					<li>
						<a href="/blog/${post.slug}/">
							<div class="post-left">
								<span class="dot"></span>
								<span class="title">${post.title}</span>
							</div>
							<span class="date">${new Date(post.pubDate).toLocaleDateString()}</span>
							<p class="description">${post.description}</p>
						</a>
					</li>
				`).join('');
			}

			document.addEventListener('DOMContentLoaded', async () => {
				await loadPosts();
				
				const searchInput = document.getElementById('search-input');
				if (!searchInput) return;

				const urlParams = new URLSearchParams(window.location.search);
				const query = urlParams.get('q');
				if (query) {
					searchInput.value = query;
					const results = searchPosts(query);
					renderResults(results);
				}

				searchInput.addEventListener('input', (e) => {
					const query = e.target.value;
					const results = searchPosts(query);
					renderResults(results);
				});
			});
		</script>
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 2em 1em;
			}
			.search-box {
				margin-bottom: 2rem;
			}
			#search-input {
				width: 100%;
				padding: 0.75rem 1rem;
				font-size: 1rem;
				border: 1px solid var(--border);
				border-radius: 8px;
				background: var(--surface);
				color: var(--text-primary);
				transition: border-color 0.2s, box-shadow 0.2s;
			}
			#search-input:focus {
				outline: none;
				border-color: var(--accent);
				box-shadow: 0 0 0 3px rgba(124, 106, 247, 0.15);
			}
			:global(.dark) #search-input {
				background: #1c1c22;
				border-color: #3f3f46;
				color: #f2f0e8;
				font-weight: 450;
			}
			:global(.dark) #search-input:focus {
				border-color: #7dd3fc;
				box-shadow: 0 0 0 3px rgba(125, 211, 252, 0.2);
			}
			:global(.dark) #search-input::placeholder {
				color: #71717a;
			}
			ul {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			li {
				padding: 0.75rem 0;
				border-bottom: 0.5px solid var(--border);
			}
			:global(.dark) li {
				border-bottom-color: #2e2e2e;
			}
			li:last-child {
				border-bottom: none;
			}
			a {
				text-decoration: none;
				display: block;
				padding: 4px 0;
				transition: padding-left 0.2s ease;
			}
			a:hover {
				padding-left: 8px;
			}
			.post-left {
				display: flex;
				align-items: center;
				gap: 10px;
				margin-bottom: 4px;
			}
			.dot {
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: var(--accent);
				flex-shrink: 0;
			}
			.title {
				color: var(--text-primary);
				font-size: 14px;
				font-weight: 500;
			}
			:global(.dark) .title {
				color: #f2f0e8;
			}
			a:hover .title {
				color: var(--accent);
			}
			.date {
				color: var(--text-muted);
				font-size: 12px;
				letter-spacing: 0.01em;
			}
			.description {
				color: var(--text-secondary);
				margin: 0.25rem 0 0 0;
				font-size: 0.9rem;
			}
			:global(.dark) .description {
				color: #a1a1aa;
			}
			.tags-section {
				margin-top: 2rem;
			}
			.all-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
			}
			.tag {
				background: var(--accent-subtle);
				padding: 0.4rem 0.8rem;
				border-radius: 999px;
				font-size: 0.85rem;
				color: var(--accent);
				text-decoration: none;
				font-weight: 450;
				transition: background-color 0.2s;
			}
			.tag:hover {
				background: var(--border);
			}
			:global(.dark) .tag {
				background: #1e1a3a;
				color: #a78bfa;
			}
			:global(.dark) .tag:hover {
				background: #2e2a4a;
				color: #c4b5fd;
			}
			:global(.dark) .tag:focus-visible {
				outline: 2px solid #7dd3fc;
				outline-offset: 2px;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<SectionHeading text="Search" />
			<div class="search-box">
				<input type="text" id="search-input" placeholder="Search posts..." />
			</div>

			<div id="results-container">
				<ul id="results">
					{posts.slice(0, 5).map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<div class="post-left">
									<span class="dot"></span>
									<span class="title">{post.data.title}</span>
								</div>
								<span class="date">
									<FormattedDate date={post.data.pubDate} />
								</span>
								<p class="description">{post.data.description}</p>
							</a>
						</li>
					))}
				</ul>
			</div>

			{allTags.length > 0 && (
				<div class="tags-section">
					<SectionHeading text="Browse by Tags" />
					<div class="all-tags">
						{allTags.map((tag) => (
							<a href={`/tags/${tag}`} class="tag">#{tag}</a>
						))}
					</div>
				</div>
			)}
		</main>
		<Footer />
	</body>
</html>
