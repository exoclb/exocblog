---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SectionHeading from '../components/SectionHeading.astro';
---
<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="About | ExocBlog" description="About me" />
		<style>
			main {
				width: 720px;
			}
			.intro {
				margin-bottom: 2rem;
			}
			.intro p {
				color: var(--text-secondary);
				margin: 0.5rem 0;
				line-height: 1.7;
			}
			:global(.dark) .intro p {
				color: #c0bdb5;
			}
			ul {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			li {
				padding: 0.5rem 0;
				border-bottom: 0.5px solid var(--border);
				color: var(--text-secondary);
				display: flex;
				align-items: center;
				gap: 8px;
			}
			:global(.dark) li {
				border-bottom-color: #2e2e2e;
				color: #c0bdb5;
			}
			li:last-child {
				border-bottom: none;
			}
			.dot {
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: var(--accent);
				flex-shrink: 0;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<SectionHeading text="About Me" />
			<div class="intro">
				<p>Hi! I'm a beginner developer learning web development.</p>
				<p>This is my personal blog where I share my learning journey.</p>
			</div>
			
			<SectionHeading text="My Skills" />
			<ul>
				<li><span class="dot"></span>HTML & CSS</li>
				<li><span class="dot"></span>JavaScript</li>
				<li><span class="dot"></span>Astro</li>
			</ul>
		</main>
		<Footer />
	</body>
</html>
