---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---
<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 720px;
			}
			.intro {
				margin-bottom: 1.5rem;
			}
			.intro p {
				color: var(--text-secondary);
				margin: 0;
			}
			:global(.dark) .intro p {
				color: #c0bdb5;
			}
			.search-container {
				margin-bottom: 1.5rem;
			}
			.search-input {
				width: 100%;
				padding: 0.75rem 1rem;
				font-size: 1rem;
				border: 1px solid var(--border);
				border-radius: 8px;
				background: var(--surface);
				color: var(--text-primary);
				transition: border-color 0.2s, box-shadow 0.2s;
			}
			.search-input:focus {
				outline: none;
				border-color: var(--accent);
				box-shadow: 0 0 0 3px rgba(124, 106, 247, 0.15);
			}
			:global(.dark) .search-input {
				background: #1c1c22;
				border-color: #3f3f46;
				color: #f2f0e8;
				font-weight: 450;
			}
			:global(.dark) .search-input:focus {
				border-color: #7dd3fc;
				box-shadow: 0 0 0 3px rgba(125, 211, 252, 0.2);
			}
			:global(.dark) .search-input::placeholder {
				color: #71717a;
			}
			ul {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			li {
				padding: 0.75rem 0;
				border-bottom: 0.5px solid var(--border);
			}
			:global(.dark) li {
				border-bottom-color: #2e2e2e;
			}
			li:last-child {
				border-bottom: none;
			}
			a {
				text-decoration: none;
				display: block;
				padding: 4px 0;
				transition: padding-left 0.2s ease;
			}
			a:hover {
				padding-left: 8px;
			}
			.post-left {
				display: flex;
				align-items: center;
				gap: 10px;
				margin-bottom: 4px;
			}
			.dot {
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: var(--accent);
				flex-shrink: 0;
			}
			.title {
				color: var(--text-primary);
				font-size: 14px;
				font-weight: 500;
			}
			:global(.dark) .title {
				color: #f2f0e8;
			}
			a:hover .title {
				color: var(--accent);
			}
			.date {
				color: var(--text-muted);
				font-size: 12px;
				letter-spacing: 0.01em;
			}
			.description {
				color: var(--text-secondary);
				margin: 0.25rem 0 0 0;
				font-size: 0.9rem;
			}
			:global(.dark) .description {
				color: #a1a1aa;
			}
			.tags {
				display: flex;
				gap: 0.5rem;
				margin-top: 0.5rem;
			}
			.tag {
				background: var(--accent-subtle);
				padding: 0.15rem 0.5rem;
				border-radius: 999px;
				font-size: 0.75rem;
				color: var(--accent);
				font-weight: 450;
			}
			:global(.dark) .tag {
				background: #1e1a3a;
				color: #a78bfa;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<SectionHeading text="Blog" />
			<div class="intro">
				<p>Writing about my learning journey.</p>
			</div>
			<div class="search-container">
				<input type="text" id="blog-search" class="search-input" placeholder="Search posts..." />
			</div>
			<ul id="posts-list">
				{
					posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<div class="post-left">
									<span class="dot"></span>
									<span class="title">{post.data.title}</span>
								</div>
								<span class="date">
									<FormattedDate date={post.data.pubDate} />
								</span>
								<p class="description">{post.data.description}</p>
								{post.data.tags && post.data.tags.length > 0 && (
									<div class="tags">
										{post.data.tags.map((tag) => (
											<span class="tag">#{tag}</span>
										))}
									</div>
								)}
							</a>
						</li>
					))
				}
			</ul>
			<p id="no-results" style="display: none;">No posts found.</p>
		</main>
		<Footer />
		<script>
			const searchInput = document.getElementById('blog-search');
			const postsList = document.getElementById('posts-list');
			const noResults = document.getElementById('no-results');
			const posts = postsList.querySelectorAll('li');

			searchInput.addEventListener('input', (e) => {
				const query = e.target.value.toLowerCase();
				let visibleCount = 0;

				posts.forEach(post => {
					const text = post.textContent.toLowerCase();
					if (text.includes(query)) {
						(post as HTMLElement).style.display = '';
						visibleCount++;
					} else {
						(post as HTMLElement).style.display = 'none';
					}
				});

				noResults.style.display = visibleCount === 0 ? 'block' : 'none';
			});
		</script>
	</body>
</html>
