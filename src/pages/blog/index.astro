---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---
<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 720px;
			}
			.search-container {
				margin-bottom: 1.5rem;
			}
			.search-input {
				width: 100%;
				padding: 0.75rem 1rem;
				font-size: 1rem;
				border: 1px solid #ddd;
				border-radius: 8px;
				background: #fff;
				color: #333;
				transition: border-color 0.2s;
			}
			.search-input:focus {
				outline: none;
				border-color: #666;
			}
			:global(.dark) .search-input {
				background: #161b22;
				border-color: #30363d;
				color: #c9d1d9;
			}
			:global(.dark) .search-input:focus {
				border-color: #8b949e;
			}
			ul {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			li {
				padding: 1rem 0;
				border-bottom: 1px solid #eee;
			}
			li:last-child {
				border-bottom: none;
			}
			a {
				text-decoration: none;
				display: block;
			}
			.title {
				font-size: 1.25rem;
				color: #333;
				margin: 0 0 0.25rem 0;
			}
			.date {
				color: #888;
				font-size: 0.85rem;
				margin: 0;
			}
			a:hover .title {
				color: #000;
			}
			.description {
				color: #666;
				margin: 0.25rem 0 0 0;
				font-size: 0.95rem;
			}
			.tags {
				display: flex;
				gap: 0.5rem;
				margin-top: 0.5rem;
			}
			.tag {
				background: #eee;
				padding: 0.15rem 0.5rem;
				border-radius: 999px;
				font-size: 0.75rem;
				color: #555;
			}
			:global(.dark) .tag {
				background: #333;
				color: #aaa;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Blog</h1>
			<p>Writing about my learning journey.</p>
			<div class="search-container">
				<input type="text" id="blog-search" class="search-input" placeholder="Search posts..." />
			</div>
			<ul id="posts-list">
				{
					posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<h3 class="title">{post.data.title}</h3>
								<p class="date">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<p class="description">{post.data.description}</p>
								{post.data.tags && post.data.tags.length > 0 && (
									<div class="tags">
										{post.data.tags.map((tag) => (
											<span class="tag">#{tag}</span>
										))}
									</div>
								)}
							</a>
						</li>
					))
				}
			</ul>
			<p id="no-results" style="display: none;">No posts found.</p>
		</main>
		<Footer />
		<script>
			const searchInput = document.getElementById('blog-search');
			const postsList = document.getElementById('posts-list');
			const noResults = document.getElementById('no-results');
			const posts = postsList.querySelectorAll('li');

			searchInput.addEventListener('input', (e) => {
				const query = e.target.value.toLowerCase();
				let visibleCount = 0;

				posts.forEach(post => {
					const text = post.textContent.toLowerCase();
					if (text.includes(query)) {
						(post as HTMLElement).style.display = '';
						visibleCount++;
					} else {
						(post as HTMLElement).style.display = 'none';
					}
				});

				noResults.style.display = visibleCount === 0 ? 'block' : 'none';
			});
		</script>
	</body>
</html>